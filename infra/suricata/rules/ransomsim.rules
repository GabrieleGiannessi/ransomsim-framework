# RansomSim -- Regole Suricata Ottimizzate (No Noise + High Visibility)
#
# PRIORITA':
#   priority:1 -> HIGH (Rosso)
#   priority:2 -> MEDIUM (Giallo)
#   priority:3 -> LOW (Blu)

# ===========================================================================
# FASE 1: RECONNAISSANCE (LOW - Priority 3)
# Usiamo 'threshold' per evitare di generare migliaia di alert per una scansione.
# ===========================================================================

# Nmap SYN scan -- Un solo alert ogni 60s per sorgente
alert tcp any any -> [10.10.1.0/24,10.10.2.0/24,10.10.3.0/24] any (msg:"RANSOMSIM RECON Nmap SYN scan detected"; flags:S; threshold: type both, track by_src, count 20, seconds 60; priority:3; classtype:network-scan; sid:9000001; rev:5;)

# Nmap service scan -- Un solo alert ogni 60s
alert tcp any any -> [10.10.1.0/24,10.10.2.0/24,10.10.3.0/24] [22,80,443,8000,8080,8443,8888] (msg:"RANSOMSIM RECON Nmap service scan"; flags:S; threshold: type both, track by_src, count 10, seconds 60; priority:3; classtype:network-scan; sid:9000002; rev:5;)

# Nikto/NSE User-Agents
alert http any any -> any any (msg:"RANSOMSIM RECON Scanner User-Agent detected"; http.user_agent; content:"Nmap Scripting Engine"; nocase; threshold: type both, track by_src, count 1, seconds 60; priority:3; classtype:network-scan; sid:9000003; rev:3;)
alert http any any -> any any (msg:"RANSOMSIM RECON Nikto web scanner"; http.user_agent; content:"Nikto"; nocase; threshold: type both, track by_src, count 1, seconds 60; priority:3; classtype:web-application-attack; sid:9000004; rev:4;)

# ===========================================================================
# FASE 2: INITIAL ACCESS (HIGH - Priority 1)
# ===========================================================================

# Command Injection su legacy/ping
alert http any any -> any 8000 (msg:"RANSOMSIM EXPLOIT Command injection on legacy/ping"; http.uri; content:"/legacy/ping"; content:"whoami"; nocase; priority:1; classtype:web-application-attack; sid:9001001; rev:5;)
alert http any any -> any 8000 (msg:"RANSOMSIM EXPLOIT Command injection passwd dump"; http.uri; content:"/legacy/ping"; content:"passwd"; nocase; priority:1; classtype:web-application-attack; sid:9001002; rev:5;)

# SQL Injection
alert http any any -> any 8000 (msg:"RANSOMSIM EXPLOIT SQL injection on legacy/search"; http.uri; content:"/legacy/search"; content:"OR"; nocase; priority:1; classtype:web-application-attack; sid:9001003; rev:5;)

# SSH Brute Force (Priority 2)
alert tcp any any -> any 22 (msg:"RANSOMSIM EXPLOIT SSH brute force attempt"; flags:S; threshold: type both, track by_src, count 5, seconds 60; priority:2; classtype:attempted-user; sid:9001004; rev:4;)

# ===========================================================================
# FASE 3: C2 BEACONING (HIGH - Priority 1)
# ===========================================================================

# Sandcat Beacon (POST /beacon) -- Cuore del C2
alert http any any -> any 8888 (msg:"RANSOMSIM C2 Sandcat beacon to Caldera"; http.method; content:"POST"; http.uri; content:"/beacon"; priority:1; classtype:trojan-activity; sid:9002001; rev:5;)

# Sandcat Result Submission (PUT /result)
alert http any any -> any 8888 (msg:"RANSOMSIM C2 Sandcat result submission"; http.method; content:"PUT"; http.uri; content:"/result"; priority:1; classtype:trojan-activity; sid:9002002; rev:5;)

# Download Agente (POST /file/download)
alert http any any -> any 8888 (msg:"RANSOMSIM C2 Sandcat agent binary download"; http.method; content:"POST"; http.uri; content:"/file/download"; priority:1; classtype:trojan-activity; sid:9002003; rev:5;)

# ===========================================================================
# FASE 4-5: DATA COLLECTION & EXFILTRATION (HIGH - Priority 1)
# ===========================================================================

# Dump Database Pazienti
alert http any any -> any 8000 (msg:"RANSOMSIM EXFILTRATION Healthcare data dump request"; http.method; content:"GET"; http.uri; content:"/patients"; priority:1; classtype:policy-violation; sid:9003001; rev:5;)

# Upload Esfiltrazione (POST /file/upload)
alert http any any -> any 8888 (msg:"RANSOMSIM EXFILTRATION Data upload to C2"; http.method; content:"POST"; http.uri; content:"/file/upload"; priority:1; classtype:policy-violation; sid:9004001; rev:5;)

# Header X-Key (Cifratura AES rilevata in transito)
alert http any any -> any 8888 (msg:"RANSOMSIM EXFILTRATION AES Key header detected"; http.header_names; content:"X-Key"; priority:1; classtype:policy-violation; sid:9004002; rev:3;)

# ===========================================================================
# FASE 7: RANSOMWARE IMPACT (HIGH - Priority 1)
# ===========================================================================

# Segnalazione cifratura completata
alert http any any -> any 8888 (msg:"RANSOMSIM IMPACT Ransomware encryption reported"; http.method; content:"PUT"; http.uri; content:"/result"; priority:1; classtype:trojan-activity; sid:9006001; rev:3;)

# ===========================================================================
# ANOMALIE & LATERAL MOVEMENT (MEDIUM - Priority 2)
# ===========================================================================

# SSH Pivot tra reti
alert tcp 10.10.2.0/24 any -> 10.10.3.0/24 22 (msg:"RANSOMSIM LATERAL MOVE SSH pivot detected"; flags:S; priority:2; classtype:attempted-admin; sid:9007001; rev:4;)
alert tcp 10.10.1.0/24 any -> 10.10.3.0/24 any (msg:"RANSOMSIM ANOMALY Attack net to Internal direct connection"; flags:S; priority:2; classtype:policy-violation; sid:9008001; rev:4;)
