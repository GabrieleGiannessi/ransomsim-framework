# ==========================================
# Ransomsim Framework - Configurazione Ambienti
# ==========================================

# 1. IP della macchina Linux (Red Team)
# Inserisci l'IP della macchina Red Team. Se tutto gira in locale, lascia localhost.
# Esempio: CALDERA_URL=http://192.168.1.100:8888
CALDERA_URL=http://localhost:8888

# 2. IP della macchina Windows (Blue Team)
# Inserisci l'IP della macchina Blue Team. Serve affinché il pannello dell'attaccante
# possa raggiungere le API corrette anziché cercare in localhost.
# Esempio: VITE_API_URL=http://192.168.1.105:8000
VITE_API_URL=http://localhost:8000
